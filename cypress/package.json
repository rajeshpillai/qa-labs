{
  "name": "qa-labs-cypress",
  "version": "1.0.0",
  "description": "Cypress tests for qa-labs testing katas",
  "scripts": {
    "serve": "serve ../katas -l 8080 --no-clipboard",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "start-server-and-test serve http://localhost:8080 cy:run",
    "test:open": "start-server-and-test serve http://localhost:8080 cy:open"
  },
  "devDependencies": {
    "cypress": "^14.3.0",
    "serve": "^14.2.4",
    "start-server-and-test": "^2.0.9",
    "typescript": "^5.7.0"
  }
}
